datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum CarStatus {
  Available
  Booked
  Maintenance
  Unavailable
  Reserved

  @@map("car_status_enum")
}

enum BookingStatus {
  Pending
  Confirmed
  InProgress @map("In Progress")
  Completed
  Cancelled
  Rejected

  @@map("booking_status_enum")
}

enum PaymentMethod {
  Cash
  CreditCard   @map("Credit Card")
  PromptPay    @map("Prompt Pay")
  BankTransfer @map("Bank Transfer")

  @@map("payment_method_enum")
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Refunded

  @@map("payment_status_enum")
}

enum MaintenanceType {
  Maintenance
  Tax
  Insurance

  @@map("maintenance_type_enum")
}

enum MaintenanceStatus {
  Pending
  Active
  Complete

  @@map("maintenance_status_enum")
}

model Image {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("images_id") @db.Uuid
  key       String   @map("images_key") @db.VarChar(255)
  url       String   @map("images_url") @db.VarChar(500)
  name      String   @map("images_name") @db.VarChar(255)
  size      BigInt   @map("images_size")
  type      String   @map("images_type") @db.VarChar(50)
  remark    String?  @map("images_remark") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy String   @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  users                 User[]
  driverCards           Driver[]   @relation("DriverCardImage")
  driverLicenses        Driver[]   @relation("DriverLicenseImage")
  carImages             CarImage[]
  bookingPayments       Booking[]  @relation("BookingPayment")
  bookingHealthCheck01s Booking[]  @relation("BookingHealthCheck01")
  bookingHealthCheck02s Booking[]  @relation("BookingHealthCheck02")

  @@map("images")
}

model VehicleType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("vehicle_type_id") @db.Uuid
  name      String   @map("vehicle_type_name") @db.VarChar(100)
  desc      String?  @map("vehicle_type_desc") @db.VarChar(255)
  remark    String?  @map("vehicle_type_remark") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy String   @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  cars Car[]

  @@map("vehicle_type")
}

model Brand {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("brand_id") @db.Uuid
  name      String   @unique @map("brand_name") @db.VarChar(100)
  desc      String?  @map("brand_desc") @db.VarChar(255)
  remark    String?  @map("brand_remark") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy String   @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  cars Car[]

  @@map("brand")
}

model Permission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("permission_id") @db.Uuid
  name      String   @map("permission_name") @db.VarChar(100)
  code      String   @unique @map("permission_code") @db.VarChar(100)
  remark    String?  @map("permission_remark") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy String   @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  menuPermissions RoleMenuPermission[]

  @@map("permission")
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("role_id") @db.Uuid
  name      String   @map("role_name") @db.VarChar(100)
  code      String   @unique @map("role_code") @db.VarChar(50)
  remark    String?  @map("role_remark") @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy String   @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  users           UserRole[]
  menuPermissions RoleMenuPermission[]

  @@map("roles")
}

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  userName       String   @unique @map("user_name") @db.VarChar(150)
  email          String   @unique @map("user_email") @db.VarChar(150)
  hashedPassword String   @map("user_password") @db.VarChar(150)
  firstName      String   @map("user_first_name") @db.VarChar(150)
  lastName       String   @map("user_last_name") @db.VarChar(150)
  phone          String   @unique @map("user_phone") @db.VarChar(20)
  cardImageId    String?  @map("user_card_image_id") @db.Uuid
  reportDownload Int      @default(0) @map("user_report_download")
  remark         String?  @map("user_remark") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy      String   @map("created_by") @db.Uuid
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy      String   @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")

  cardImage Image?     @relation(fields: [cardImageId], references: [id])
  roles     UserRole[]
  bookings  Booking[]

  @@index([isDeleted], map: "idx_user_deleted")
  @@map("user")
}

model Driver {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @map("driver_id") @db.Uuid
  fullName       String   @map("driver_full_name") @db.VarChar(150)
  phone          String   @unique @map("driver_phone") @db.VarChar(20)
  cardImageId    String?  @map("driver_card_images_id") @db.Uuid
  licenseImageId String?  @map("driver_license_images_id") @db.Uuid
  remark         String?  @map("driver_remark") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy      String   @map("created_by") @db.Uuid
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy      String   @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")

  cardImage    Image?    @relation("DriverCardImage", fields: [cardImageId], references: [id])
  licenseImage Image?    @relation("DriverLicenseImage", fields: [licenseImageId], references: [id])
  bookings     Booking[]

  @@map("driver")
}

model Car {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @map("cars_id") @db.Uuid
  vehicleTypeId String    @map("vehicle_type_id") @db.Uuid
  brandId       String    @map("brand_id") @db.Uuid
  mileage       Decimal   @default(0) @map("cars_mileage") @db.Decimal(12, 2)
  model         String    @map("cars_model") @db.VarChar(100)
  year          String    @map("cars_years") @db.VarChar(4)
  color         String    @map("cars_color") @db.VarChar(50)
  license       String    @unique @map("cars_license") @db.VarChar(20)
  status        CarStatus @default(Available) @map("cars_status")
  remark        String?   @map("cars_remark") @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_date") @db.Timestamptz
  createdBy     String    @map("created_by") @db.Uuid
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy     String    @map("updated_by") @db.Uuid
  isDeleted     Boolean   @default(false) @map("is_deleted")

  vehicleType  VehicleType   @relation(fields: [vehicleTypeId], references: [id])
  brand        Brand         @relation(fields: [brandId], references: [id])
  images       CarImage[]
  maintenances Maintenance[]
  bookings     Booking[]

  @@index([isDeleted], map: "idx_cars_deleted")
  @@map("cars")
}

model Menu {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @map("menu_id") @db.Uuid
  key                String   @unique @map("menu_key") @db.VarChar(100)
  name               String   @map("menu_name") @db.VarChar(150)
  icon               String?  @map("menu_icon") @db.VarChar(100)
  path               String?  @map("menu_path") @db.VarChar(255)
  parentId           String?  @map("menu_parent_id") @db.Uuid
  sequence           Int      @map("menu_sequence")
  remark             String?  @map("menu_remark") @db.VarChar(500)
  requiredPermission String?  @map("required_permission") @db.VarChar(100)
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy          String   @map("created_by") @db.Uuid
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy          String   @map("updated_by") @db.Uuid
  isDeleted          Boolean  @default(false) @map("is_deleted")

  parent          Menu?                @relation("MenuToMenu", fields: [parentId], references: [id], onDelete: Cascade)
  children        Menu[]               @relation("MenuToMenu")
  menuPermissions RoleMenuPermission[]

  @@map("menu")
}

model Product {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("products_id") @db.Uuid
  name      String   @map("products_name") @db.VarChar(255)
  desc      String?  @map("products_desc") @db.VarChar(255)
  remark    String?  @map("products_remark") @db.VarChar(500)
  price     Decimal  @default(0) @map("products_price") @db.Decimal(12, 2)
  dateStart DateTime @map("date_start") @db.Timestamptz
  dateEnd   DateTime @map("date_end") @db.Timestamptz
  dateCount Int      @default(0) @map("date_count")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy String   @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  bookings Booking[]

  @@map("products")
}

model CarImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("map_cars_images_id") @db.Uuid
  carId     String   @map("cars_id") @db.Uuid
  imageId   String   @map("images_id") @db.Uuid
  type      String   @map("cars_images_type") @db.VarChar(150)
  number    Int      @default(0) @map("cars_images_numb")
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid

  car   Car   @relation(fields: [carId], references: [id], onDelete: Cascade)
  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@map("map_cars_images")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("map_user_role_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy String   @map("created_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("map_user_roles")
}

model RoleMenuPermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @map("map_rmp_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  menuId       String   @map("menu_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_date") @db.Timestamptz
  createdBy    String   @map("created_by") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@map("map_role_menu_permissions")
}

model Maintenance {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @map("maintenances_id") @db.Uuid
  carId         String            @map("cars_id") @db.Uuid
  name          String            @map("maintenances_name") @db.VarChar(255)
  desc          String?           @map("maintenances_desc") @db.VarChar(255)
  remark        String?           @map("maintenances_remark") @db.VarChar(500)
  type          MaintenanceType   @default(Maintenance) @map("maintenances_type")
  status        MaintenanceStatus @default(Pending) @map("maintenances_status")
  mileage       Int               @default(0)
  mileageTarget Int               @default(0) @map("mileage_target")
  mileageAlert  Int               @default(0) @map("mileage_alert")
  dateAlert     DateTime?         @map("date_alert") @db.Timestamptz
  dateStart     DateTime          @map("date_start") @db.Timestamptz
  dateEnd       DateTime          @map("date_end") @db.Timestamptz
  dateCount     Int               @default(0) @map("date_count")
  createdAt     DateTime          @default(now()) @map("created_date") @db.Timestamptz
  createdBy     String            @map("created_by") @db.Uuid
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy     String            @map("updated_by") @db.Uuid
  isDeleted     Boolean           @default(false) @map("is_deleted")

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@map("maintenances")
}

model Booking {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @map("booking_id") @db.Uuid
  productId            String        @map("products_id") @db.Uuid
  carId                String        @map("cars_id") @db.Uuid
  userId               String        @map("user_id") @db.Uuid
  driverId             String?       @map("driver_id") @db.Uuid
  paymentImageId       String?       @map("booking_payment_images_id") @db.Uuid
  healthCheck01ImageId String?       @map("booking_health_check_01_images_id") @db.Uuid
  healthCheck02ImageId String?       @map("booking_health_check_02_images_id") @db.Uuid
  dateStart            DateTime      @map("date_start") @db.Timestamptz
  dateEnd              DateTime      @map("date_end") @db.Timestamptz
  dateCount            Int           @default(0) @map("date_count")
  price                Decimal       @default(0) @db.Decimal(12, 2)
  dailyRate            Decimal       @default(0) @map("daily_rate") @db.Decimal(12, 2)
  discountAmount       Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount            Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  netAmount            Decimal       @default(0) @map("net_amount") @db.Decimal(12, 2)
  status               BookingStatus @default(Pending) @map("booking_status")
  remark               String?       @map("booking_remark") @db.VarChar(500)
  createdAt            DateTime      @default(now()) @map("created_date") @db.Timestamptz
  createdBy            String        @map("created_by") @db.Uuid
  updatedAt            DateTime      @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy            String        @map("updated_by") @db.Uuid
  isDeleted            Boolean       @default(false) @map("is_deleted")

  product            Product   @relation(fields: [productId], references: [id])
  car                Car       @relation(fields: [carId], references: [id])
  user               User      @relation(fields: [userId], references: [id])
  driver             Driver?   @relation(fields: [driverId], references: [id])
  paymentImage       Image?    @relation("BookingPayment", fields: [paymentImageId], references: [id])
  healthCheck01Image Image?    @relation("BookingHealthCheck01", fields: [healthCheck01ImageId], references: [id])
  healthCheck02Image Image?    @relation("BookingHealthCheck02", fields: [healthCheck02ImageId], references: [id])
  payments           Payment[]

  @@index([status], map: "idx_booking_status")
  @@index([isDeleted], map: "idx_booking_deleted")
  @@map("booking")
}

model Payment {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @map("payments_id") @db.Uuid
  bookingId     String        @map("booking_id") @db.Uuid
  paymentDate   DateTime      @default(now()) @map("payment_date") @db.Timestamptz
  amount        Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(Pending) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_date") @db.Timestamptz
  createdBy     String        @map("created_by") @db.Uuid
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_date") @db.Timestamptz
  updatedBy     String        @map("updated_by") @db.Uuid
  isDeleted     Boolean       @default(false) @map("is_deleted")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId], map: "idx_payments_booking")
  @@map("payments")
}
